generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum AppRole {
  operator
  grow_manager
  admin
}

enum AuditEventType {
  command
  planting
  harvest
}

enum CropBatchStatus {
  planned
  active
  harvested
  archived
}

enum QualityGrade {
  A
  B
  C
  reject
}

enum CommandSource {
  manual
  autonomous
}

enum CommandLifecycle {
  queued
  validated
  blocked
  sent
  acked
  failed
  timed_out
}

enum AlertSeverity {
  info
  warning
  critical
}

enum AlertComparison {
  gt
  gte
  lt
  lte
}

enum AlertEventStatus {
  open
  acknowledged
  resolved
}

enum ZoneType {
  tier_as_zone
  column_as_zone
  custom
}

enum ZoneRecipeAssignmentStatus {
  active
  completed
  cancelled
}

enum AutonomyRiskLevel {
  low
  high
}

enum AutonomyRecommendationStatus {
  proposed
  approved
  rejected
  executed
  blocked
}

model AuditEvent {
  id         String         @id
  actorUserId String
  role       AppRole
  eventType  AuditEventType
  action     String
  targetType String
  targetId   String?
  details    Json?
  createdAt  DateTime

  @@index([createdAt])
  @@index([actorUserId])
}

model Command {
  id                 String          @id
  farmId             String
  zoneId             String?
  actuatorId         String?
  source             CommandSource
  lifecycle          CommandLifecycle
  action             String
  payload            Json?
  requestedByUserId  String
  requestedByRole    AppRole
  validationMessage  String?
  blockedReason      String?
  cooldownUntil      DateTime?
  createdAt         DateTime
  updatedAt         DateTime

  executions CommandExecution[]

  @@index([createdAt])
  @@index([farmId])
  @@index([zoneId])
  @@index([source])
  @@index([lifecycle])
}

model CommandExecution {
  id              String          @id
  commandId       String
  lifecycle       CommandLifecycle
  validationMessage String?
  dispatchedAt    DateTime?
  acknowledgedAt  DateTime?
  failedAt        DateTime?
  timeoutAt       DateTime?
  createdAt       DateTime
  updatedAt       DateTime

  command Command @relation(fields: [commandId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([commandId])
  @@index([createdAt])
  @@index([lifecycle])
}

model TelemetryPoint {
  id         String   @id
  farmId     String
  zoneId     String
  deviceId   String?
  sensorType String?
  metric     String
  value      Float
  unit       String?
  recordedAt DateTime
  createdAt  DateTime

  @@index([createdAt])
  @@index([farmId])
  @@index([zoneId])
  @@index([metric])
  @@index([recordedAt])
}

model AlertRule {
  id               String          @id
  farmId           String
  zoneId           String?
  metric           String
  comparison       AlertComparison
  threshold        Float
  durationSeconds  Int             @default(0)
  severity         AlertSeverity
  enabled          Boolean         @default(true)
  createdByUserId  String
  createdAt        DateTime
  updatedAt        DateTime

  events AlertEvent[]

  @@index([farmId])
  @@index([zoneId])
  @@index([metric])
  @@index([enabled])
}

model AlertEvent {
  id                    String           @id
  ruleId                String
  farmId                String
  zoneId                String?
  severity              AlertSeverity
  status                AlertEventStatus @default(open)
  message               String
  triggeredValue        Float
  acknowledgedAt        DateTime?
  acknowledgedByUserId  String?
  resolvedAt            DateTime?
  resolvedByUserId      String?
  triggeredAt           DateTime
  createdAt             DateTime

  rule AlertRule @relation(fields: [ruleId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([createdAt])
  @@index([farmId])
  @@index([zoneId])
  @@index([status])
  @@index([severity])
}

model DeviceHeartbeat {
  id         String   @id
  farmId     String
  zoneId     String?
  deviceId   String   @unique
  status     String
  lastSeenAt DateTime
  metadata   Json?
  createdAt  DateTime
  updatedAt  DateTime

  @@index([farmId])
  @@index([zoneId])
  @@index([lastSeenAt])
}

model Zone {
  id            String   @id
  farmId        String
  name          String
  zoneType      ZoneType
  memberIds     Json
  actuatorGroup String?
  notes         String?
  createdAt     DateTime
  updatedAt     DateTime

  assignments ZoneRecipeAssignment[]

  @@index([farmId])
  @@index([name])
  @@index([zoneType])
  @@index([actuatorGroup])
}

model RecipeDefinition {
  id               String   @id
  farmId           String
  name             String
  cropName         String?
  topologyMode     ZoneType
  notes            String?
  createdByUserId  String
  createdAt        DateTime
  updatedAt        DateTime

  phases RecipePhase[]
  assignments ZoneRecipeAssignment[]

  @@index([farmId])
  @@index([name])
  @@index([topologyMode])
}

model RecipePhase {
  id           String   @id
  recipeId     String
  name         String
  phaseOrder   Int
  durationDays Int?
  setpoints    Json
  createdAt    DateTime
  updatedAt    DateTime

  recipe RecipeDefinition @relation(fields: [recipeId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([recipeId])
  @@index([phaseOrder])
}

model ZoneRecipeAssignment {
  id         String                     @id
  farmId     String
  zoneId     String
  recipeId   String
  status     ZoneRecipeAssignmentStatus @default(active)
  startedAt  DateTime
  endedAt    DateTime?
  notes      String?
  createdAt  DateTime
  updatedAt  DateTime

  zone Zone @relation(fields: [zoneId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  recipe RecipeDefinition @relation(fields: [recipeId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([farmId])
  @@index([zoneId])
  @@index([recipeId])
  @@index([status])
  @@index([startedAt])
}

model AutonomyRecommendation {
  id                  String                       @id
  farmId              String
  zoneId              String
  recipeId            String
  recipePhaseId       String?
  metric              String
  currentValue        Float
  targetValue         Float
  deviation           Float
  riskLevel           AutonomyRiskLevel
  status              AutonomyRecommendationStatus @default(proposed)
  title               String
  rationale           String
  recommendedAction   String
  command             String
  payload             Json?
  requiresApproval    Boolean                      @default(false)
  commandId           String?
  blockedReason       String?
  decidedByUserId     String?
  decidedAt           DateTime?
  executedAt          DateTime?
  createdAt           DateTime
  updatedAt           DateTime

  @@index([farmId])
  @@index([zoneId])
  @@index([status])
  @@index([riskLevel])
  @@index([createdAt])
}

model PlantingBatch {
  id                     String          @id
  batchCode              String          @unique
  cropCatalogId          String?
  cropName               String
  cultivar               String?
  zoneId                 String
  plantedAt              DateTime
  expectedHarvestStartAt DateTime?
  expectedHarvestEndAt   DateTime?
  status                 CropBatchStatus
  startedByUserId        String
  createdAt              DateTime
  updatedAt              DateTime

  cropCatalog CropCatalogItem?     @relation(fields: [cropCatalogId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  harvests HarvestRecord[]
  zoneAssignments BatchZoneAssignment[]

  @@index([createdAt])
  @@index([cropCatalogId])
  @@index([zoneId])
}

model CropCatalogItem {
  id             String   @id
  cropName       String
  cultivar       String?
  seedSupplier   String?
  seedLotCode    String?
  targetCycleDays Int?
  notes          String?
  createdAt      DateTime
  updatedAt      DateTime

  batches PlantingBatch[]

  @@index([createdAt])
  @@index([cropName])
}

model BatchZoneAssignment {
  id               String   @id
  batchId          String
  zoneId           String
  assignedAt       DateTime
  unassignedAt     DateTime?
  assignmentReason String?
  createdAt        DateTime

  batch PlantingBatch @relation(fields: [batchId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@index([batchId])
  @@index([assignedAt])
  @@index([zoneId])
}

model HarvestRecord {
  id             String   @id
  batchId        String
  zoneId         String
  harvestedAt    DateTime
  operatorUserId String
  usableWeightKg Float
  rejectWeightKg Float
  wetWeightKg    Float?
  dryWeightKg    Float?
  qualityGrade   QualityGrade?
  defectNotes    String?
  finalized      Boolean  @default(false)
  finalizedAt    DateTime?
  notes          String?
  createdAt      DateTime

  batch PlantingBatch @relation(fields: [batchId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([batchId])
  @@index([createdAt])
  @@index([zoneId])
}
